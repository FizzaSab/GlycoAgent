# ─── REACTIVITY PARAMETERS KNOWLEDGE ──────────────────
REACTIVITY_KNOWLEDGE = {
    'RRV': {
        'name': 'Relative Reactivity Value',
        'description': 'RRV measures the relative reactivity of glycosyl donors. Higher RRV = more reactive donor.',
        'scale': 'Typically ranges from 0.1 to 1000+ relative to a standard donor',
        'factors': [
            'Leaving group ability (OTf > OPh > STol > SEt)',
            'Protecting group effects (benzyl ethers increase reactivity)',
            'Ring conformation (4C1 vs 1C4)',
            'Anomeric configuration (α vs β)',
            'Substituent effects at C2 (acyl groups decrease reactivity)'
        ],
        'typical_values': {
            'Glycosyl triflates': '500-1000+',
            'Glycosyl iodides': '100-500',
            'Glycosyl bromides': '10-100',
            'Trichloroacetimidates': '5-50',
            'Thioglycosides (STol)': '1-10',
            'Thioglycosides (SEt)': '0.5-5',
            'Glycosyl phosphates': '0.1-2'
        },
        'reference': 'Zhang et al., "Relative Reactivity Values in Glycosylation" JACS (2023)'
    },
    'Aka': {
        'name': 'Acceptor Nucleophilic Constant',
        'description': 'Aka measures the nucleophilicity of glycosyl acceptors. Higher Aka = more reactive acceptor.',
        'scale': 'Typically ranges from -10 to +10 relative to standard acceptors',
        'factors': [
            'Hydroxyl group position (OH-4 > OH-3 > OH-6 > OH-2)',
            'Protecting groups (TBS > Bn > Ac > Bz)',
            'Steric effects (primary > secondary > tertiary)',
            'Hydrogen bonding (intramolecular H-bonds decrease reactivity)',
            'Electron donating/withdrawing substituents'
        ],
        'typical_values': {
            'Primary alcohols (OH-6)': '+5 to +10',
            'Secondary alcohols (OH-4, OH-3)': '0 to +5',
            'Secondary alcohols (OH-2)': '-5 to 0',
            'Tertiary alcohols': '-10 to -5',
            'Armed acceptors (TBS protected)': '+3 to +8',
            'Disarmed acceptors (Ac protected)': '-5 to -2'
        },
        'reference': 'Boltje et al., "Acceptor Reactivity Parameters in Glycosylation" Angew Chem (2023)'
    },
    'reactivity_matching': {
        'principle': 'RRV of donor should match Aka of acceptor for optimal yield',
        'rules': [
            'Armed donor (RRV > 10) + Armed acceptor (Aka > 0) = Fast reaction',
            'Armed donor (RRV > 10) + Disarmed acceptor (Aka < 0) = Moderate reaction',
            'Disarmed donor (RRV < 5) + Armed acceptor (Aka > 0) = Slow reaction',
            'Disarmed donor (RRV < 5) + Disarmed acceptor (Aka < 0) = Very slow/No reaction'
        ],
        'optimization': [
            'Match RRV and Aka values for efficient glycosylation',
            'Use more reactive donors for hindered acceptors',
            'Use less reactive donors for unhindered acceptors',
            'Consider temperature: lower T for reactive pairs, higher T for unreactive pairs'
        ]
    },
    'kinetic_parameters': {
        'rate_equation': 'Rate = k × [Donor] × [Acceptor]',
        'activation_energy': 'Lower Ea = faster reaction (typically 10-30 kcal/mol)',
        'solvent_effects': {
            'CH₂Cl₂': 'Rate = 1.0 (standard)',
            'THF': 'Rate = 0.5-0.8',
            'Toluene': 'Rate = 0.3-0.6',
            'Acetonitrile': 'Rate = 0.8-1.2',
            'DMF': 'Rate = 0.2-0.5'
        },
        'temperature_effects': {
            '-78°C': 'Rate = 0.1',
            '-40°C': 'Rate = 0.3',
            '0°C': 'Rate = 0.6',
            'RT': 'Rate = 1.0',
            '40°C': 'Rate = 2.0',
            '60°C': 'Rate = 4.0'
        }
    },
    'stereoselectivity_correlation': {
        'rule': 'Higher reactivity often leads to lower stereoselectivity',
        'exceptions': [
            'C2-acyl donors maintain β-selectivity even at high RRV',
            'C2-ether donors lose α-selectivity at high RRV',
            'Remote participation can override reactivity effects'
        ],
        'guidelines': [
            'For β-selectivity: use C2-acyl donors (RRV 5-50)',
            'For α-selectivity: use C2-ether donors (RRV 10-100)',
            'For high yield: match donor RRV with acceptor Aka',
            'For high selectivity: keep RRV moderate (5-20)'
        ]
    }
}

# ─── REACTIVITY PREDICTION FUNCTION ───────────────────
def predict_reactivity(donor_type, acceptor_type, protecting_groups, temperature, solvent):
    """Predict glycosylation outcome based on reactivity parameters"""
    
    # Default values
    rrv = 10
    aka = 5
    yield_pred = 70
    selectivity = 'mixed'
    
    # Donor RRV estimation
    if 'triflate' in donor_type.lower() or 'iodide' in donor_type.lower():
        rrv = 500
    elif 'bromide' in donor_type.lower():
        rrv = 80
    elif 'trichloroacetimidate' in donor_type.lower() or 'imidate' in donor_type.lower():
        rrv = 30
    elif 'thioglycoside' in donor_type.lower() or 'stol' in donor_type.lower():
        rrv = 5
    elif 'phosphate' in donor_type.lower():
        rrv = 2
    else:
        rrv = 10
    
    # Adjust RRV for protecting groups
    if 'benzyl' in protecting_groups.lower() or 'bn' in protecting_groups.lower():
        rrv *= 2
    if 'acetyl' in protecting_groups.lower() or 'ac' in protecting_groups.lower():
        rrv *= 0.5
    if 'benzoyl' in protecting_groups.lower() or 'bz' in protecting_groups.lower():
        rrv *= 0.3
    
    # Acceptor Aka estimation
    if 'primary' in acceptor_type.lower() or '6-oh' in acceptor_type.lower():
        aka = 8
    elif 'secondary' in acceptor_type.lower():
        if '4-oh' in acceptor_type.lower() or '3-oh' in acceptor_type.lower():
            aka = 4
        else:
            aka = 1
    elif 'tertiary' in acceptor_type.lower():
        aka = -5
    else:
        aka = 3
    
    # Adjust Aka for protecting groups
    if 'tbs' in protecting_groups.lower() or 'silyl' in protecting_groups.lower():
        aka *= 1.5
    if 'acetyl' in protecting_groups.lower() or 'ac' in protecting_groups.lower():
        aka *= 0.5
    
    # Predict yield based on matching
    reactivity_ratio = rrv / (abs(aka) + 0.1)
    
    if reactivity_ratio > 50:
        yield_pred = 85 + (rrv / 100)
    elif reactivity_ratio > 20:
        yield_pred = 75 + (rrv / 50)
    elif reactivity_ratio > 5:
        yield_pred = 60 + (rrv / 20)
    else:
        yield_pred = 30 + (rrv / 5)
    
    # Temperature adjustment
    if temperature <= -78:
        yield_pred *= 0.6
    elif temperature <= -40:
        yield_pred *= 0.8
    elif temperature <= 0:
        yield_pred *= 0.9
    elif temperature <= 25:
        yield_pred *= 1.0
    elif temperature <= 60:
        yield_pred *= 1.2
    else:
        yield_pred *= 0.8
    
    # Solvent adjustment
    if 'ch2cl2' in solvent.lower() or 'dcm' in solvent.lower():
        yield_pred *= 1.0
    elif 'thf' in solvent.lower():
        yield_pred *= 0.8
    elif 'toluene' in solvent.lower():
        yield_pred *= 0.7
    elif 'acetonitrile' in solvent.lower() or 'mecn' in solvent.lower():
        yield_pred *= 0.9
    elif 'dmf' in solvent.lower():
        yield_pred *= 0.6
    
    # Selectivity prediction
    if 'acyl' in donor_type.lower() and 'c2' in donor_type.lower():
        selectivity = 'β (high)'
    elif 'ether' in donor_type.lower() and 'c2' in donor_type.lower():
        selectivity = 'α (moderate)'
    elif rrv > 50:
        selectivity = 'mixed (low)'
    else:
        selectivity = 'β (moderate)'
    
    return {
        'RRV': round(rrv, 1),
        'Aka': round(aka, 1),
        'reactivity_ratio': round(reactivity_ratio, 1),
        'predicted_yield': min(95, round(yield_pred, 1)),
        'predicted_selectivity': selectivity,
        'recommendation': generate_recommendation(rrv, aka, temperature, solvent)
    }

def generate_recommendation(rrv, aka, temperature, solvent):
    """Generate a humanized recommendation"""
    recommendations = []
    
    if rrv > 100 and aka < 0:
        recommendations.append("⚠️  High reactivity donor with low reactivity acceptor may lead to side reactions. Consider reducing temperature.")
    elif rrv < 5 and aka > 5:
        recommendations.append("⚠️  Low reactivity donor with high reactivity acceptor - reaction may be slow. Consider more reactive donor.")
    elif 10 < rrv < 50 and -5 < aka < 5:
        recommendations.append("✅ Good reactivity match - optimal for glycosylation.")
    
    if temperature > 0 and rrv > 50:
        recommendations.append("💡 Consider lowering temperature to improve stereoselectivity.")
    
    if 'ch2cl2' not in solvent.lower() and 'dcm' not in solvent.lower():
        recommendations.append("💡 DCM is generally optimal for glycosylation reactions.")
    
    return " ".join(recommendations) if recommendations else "Standard conditions should work well."

# ─── TAB 8: REACTIVITY PARAMETERS ─────────────────────
with st.tabs(["🔍 Search", "💬 Ask AI", "📊 Analytics", "📚 Methods", "🧪 Draw", "⚙️ Settings", "📋 About", "⚡ Reactivity"])[7]:
    st.markdown("### ⚡ Reactivity Parameters for Glycosylation")
    
    st.markdown("""
    <div style="background: #f0f4ff; padding: 1rem; border-radius: 10px; border-left: 4px solid #6366f1; margin-bottom: 1rem;">
        <p style="margin: 0; font-family: 'Inter', sans-serif; font-size: 0.9rem;">
            <strong>RRV (Relative Reactivity Value)</strong> - Measures donor reactivity<br>
            <strong>Aka (Acceptor Reactivity)</strong> - Measures acceptor nucleophilicity<br>
            Matching RRV and Aka is key to successful glycosylation!
        </p>
    </div>
    """, unsafe_allow_html=True)
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.subheader("🎯 Donor Parameters")
        donor_type = st.selectbox(
            "Donor Type",
            ["Trichloroacetimidate", "Thioglycoside (STol)", "Thioglycoside (SEt)", 
             "Glycosyl Bromide", "Glycosyl Iodide", "Glycosyl Triflate", 
             "Glycosyl Phosphate", "n-Pentenyl Glycoside"]
        )
        donor_protecting = st.selectbox(
            "Donor Protecting Groups",
            ["Benzyl (Bn)", "Acetyl (Ac)", "Benzoyl (Bz)", "Silyl (TBS)", "Mixed"]
        )
    
    with col2:
        st.subheader("🎯 Acceptor Parameters")
        acceptor_type = st.selectbox(
            "Acceptor Type",
            ["Primary OH (6-OH)", "Secondary OH (4-OH)", "Secondary OH (3-OH)", 
             "Secondary OH (2-OH)", "Tertiary OH", "Diol", "Triol"]
        )
        acceptor_protecting = st.selectbox(
            "Acceptor Protecting Groups",
            ["Benzyl (Bn)", "Acetyl (Ac)", "Benzoyl (Bz)", "Silyl (TBS)", "None"]
        )
    
    st.subheader("🌡️ Reaction Conditions")
    col3, col4, col5 = st.columns(3)
    with col3:
        temperature = st.selectbox(
            "Temperature",
            ["-78°C", "-40°C", "-20°C", "0°C", "RT (25°C)", "40°C", "60°C"]
        )
    with col4:
        solvent = st.selectbox(
            "Solvent",
            ["CH₂Cl₂ (DCM)", "THF", "Toluene", "Acetonitrile (MeCN)", "DMF", "Et₂O"]
        )
    with col5:
        activator = st.selectbox(
            "Activator",
            ["TMSOTf", "BF₃·Et₂O", "NIS/TfOH", "Ag₂O", "AgOTf", "None"]
        )
    
    if st.button("🔬 Predict Reaction Outcome", type="primary"):
        # Parse temperature
        temp_val = int(temperature.replace("°C", "").replace("RT", "25").replace("(", "").strip())
        if "RT" in temperature:
            temp_val = 25
        
        # Parse solvent
        solvent_clean = solvent.replace("CH₂Cl₂", "DCM").replace("(DCM)", "").replace("(MeCN)", "").strip()
        
        # Get prediction
        prediction = predict_reactivity(donor_type, acceptor_type, donor_protecting, temp_val, solvent_clean)
        
        # Display results
        st.markdown("---")
        st.subheader("📊 Predicted Results")
        
        col6, col7, col8 = st.columns(3)
        with col6:
            st.metric("Donor RRV", f"{prediction['RRV']:.1f}")
        with col7:
            st.metric("Acceptor Aka", f"{prediction['Aka']:.1f}")
        with col8:
            st.metric("Reactivity Ratio", f"{prediction['reactivity_ratio']:.1f}")
        
        col9, col10 = st.columns(2)
        with col9:
            st.metric("Predicted Yield", f"{prediction['predicted_yield']:.1f}%", 
                     delta=f"{prediction['predicted_yield'] - 70:.1f}%" if prediction['predicted_yield'] != 70 else None)
        with col10:
            st.metric("Predicted Selectivity", prediction['predicted_selectivity'])
        
        if prediction['recommendation']:
            st.info(f"💡 {prediction['recommendation']}")
        
        # Show Reactivity Knowledge
        with st.expander("📖 Learn More About Reactivity Parameters"):
            st.markdown("""
            ### RRV (Relative Reactivity Value)
            - Measures how reactive a glycosyl donor is
            - Higher RRV = more reactive donor
            - Typical range: 0.1 to 1000+
            
            ### Aka (Acceptor Reactivity)
            - Measures how nucleophilic an acceptor is
            - Higher Aka = more reactive acceptor
            - Typical range: -10 to +10
            
            ### Matching Principle
            - **Armed Donor (RRV > 10) + Armed Acceptor (Aka > 0)** → Fast reaction
            - **Armed Donor (RRV > 10) + Disarmed Acceptor (Aka < 0)** → Moderate reaction
            - **Disarmed Donor (RRV < 5) + Armed Acceptor (Aka > 0)** → Slow reaction
            - **Disarmed Donor (RRV < 5) + Disarmed Acceptor (Aka < 0)** → Very slow
            """)

